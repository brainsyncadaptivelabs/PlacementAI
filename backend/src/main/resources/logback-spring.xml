<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Read properties from environment or fallback to default -->
    <springProperty scope="context" name="logLevel" source="logging.level.root" defaultValue="${LOGGING_LEVEL:-INFO}"/>
    <springProperty scope="context" name="logLevelApp" source="logging.level.com.aiplacement.backend" defaultValue="${LOGGING_LEVEL_APP:-INFO}"/>
    <springProperty scope="context" name="logRetentionDays" source="logging.retention.days" defaultValue="${LOG_RETENTION_DAYS:-30}"/>
    <springProperty scope="context" name="logMaxFileSize" source="logging.max.file-size" defaultValue="${LOG_MAX_FILE_SIZE:-10MB}"/>

    <!-- Log Pattern with MDC details (Correlation / Request ID, User ID) -->
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - [ReqId: %X{requestId}, User: %X{userId}] - %msg%n"/>

    <!-- Console Appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- Application File Appender -->
    <appender name="APPLICATION_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/application.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/archived/application-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${logMaxFileSize}</maxFileSize>
            <maxHistory>${logRetentionDays}</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- AI Logger File Appender -->
    <appender name="AI_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/ai.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/archived/ai-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${logMaxFileSize}</maxFileSize>
            <maxHistory>${logRetentionDays}</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- Security Logger File Appender -->
    <appender name="SECURITY_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/security.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/archived/security-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${logMaxFileSize}</maxFileSize>
            <maxHistory>${logRetentionDays}</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- Error File Appender (Captures WARN and ERROR levels only) -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/error.log</file>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>WARN</level>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/archived/error-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${logMaxFileSize}</maxFileSize>
            <maxHistory>${logRetentionDays}</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- Loggers configuration -->
    <logger name="com.aiplacement.backend" level="${logLevelApp}" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="APPLICATION_FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </logger>

    <!-- AI Logger -->
    <logger name="com.aiplacement.backend.ai" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="AI_FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </logger>

    <!-- Security Logger -->
    <logger name="com.aiplacement.backend.security" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="SECURITY_FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </logger>
    <logger name="org.springframework.security" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="SECURITY_FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </logger>

    <!-- Root Logger -->
    <root level="${logLevel}">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="APPLICATION_FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </root>

</configuration>
