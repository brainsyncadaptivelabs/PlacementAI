# ============================================================
# PlacementAI – Backend Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control — only .env.example
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_URL=jdbc:mysql://localhost:3306/placementai
DB_USERNAME=root
DB_PASSWORD=

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── NVIDIA Build API ─────────────────────────────────────────
# Required — get your key at: https://build.nvidia.com
NVIDIA_API_KEY=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
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_TEMPERATURE=0.2
NVIDIA_TOP_P=0.7
NVIDIA_MAX_TOKENS=1024
NVIDIA_TIMEOUT_SECONDS=120
NVIDIA_RETRY_ATTEMPTS=3
NVIDIA_RETRY_DELAY_MS=1000

# ── Code Execution (Piston) ───────────────────────────────────
PISTON_API_URL=http://localhost:2000/api/v2

# ── Mail ─────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# ── Cloudinary (Resume Storage) ──────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ── Admin ────────────────────────────────────────────────────
ADMIN_REGISTRATION_CODE=

# ── Frontend ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Web Push (VAPID) ─────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@aiplacement.com