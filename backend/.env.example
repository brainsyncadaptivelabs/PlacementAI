# ============================================================
# PlacementAI – Backend Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control — only .env.example
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_URL=jdbc:mysql://localhost:3306/placementai
DB_USERNAME=root
DB_PASSWORD=

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── NVIDIA Build API ─────────────────────────────────────────
# Required — get your key at: https://build.nvidia.com
NVIDIA_API_KEY=YOUR_NVIDIA_API_KEY
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_TEMPERATURE=0.2
NVIDIA_TOP_P=0.7
NVIDIA_MAX_TOKENS=1024
NVIDIA_TIMEOUT_SECONDS=120
NVIDIA_RETRY_ATTEMPTS=3
NVIDIA_RETRY_DELAY_MS=1000

# ── Code Execution (Piston) ───────────────────────────────────
PISTON_API_URL=http://localhost:2000/api/v2

# ── Mail ─────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# ── Cloudinary (Resume Storage) ──────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ── Admin ────────────────────────────────────────────────────
ADMIN_REGISTRATION_CODE=

# ── Frontend ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Web Push (VAPID) ─────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@aiplacement.com

# ── Logging ──────────────────────────────────────────────────
LOGGING_LEVEL=INFO
LOGGING_LEVEL_APP=DEBUG
LOG_RETENTION_DAYS=30

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_LOGIN_CAPACITY=5
RATE_LIMIT_LOGIN_DURATION=60
RATE_LIMIT_SIGNUP_CAPACITY=3
RATE_LIMIT_SIGNUP_DURATION=3600
RATE_LIMIT_CHAT_CAPACITY=60
RATE_LIMIT_CHAT_DURATION=60
RATE_LIMIT_RESUME_CAPACITY=10
RATE_LIMIT_RESUME_DURATION=3600
RATE_LIMIT_ATS_CAPACITY=20
RATE_LIMIT_ATS_DURATION=3600
RATE_LIMIT_INTERVIEW_CAPACITY=15
RATE_LIMIT_INTERVIEW_DURATION=3600

# ── Backup ───────────────────────────────────────────────────
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7