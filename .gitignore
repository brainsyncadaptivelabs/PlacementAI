# ============================================================
# PlacementAI – Global .gitignore
# ============================================================

# Environment Files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*_env*.zip
!/.env.example

# OS Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Node (Frontend)
node_modules/
.next/
out/
build/
dist/
.pnp
.pnp.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.tsbuildinfo
next-env.d.ts
.vercel

# Java / Maven (Backend)
target/
*.class
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.restoreBackup
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
# Avoid ignoring Maven wrapper jar
!.mvn/wrapper/maven-wrapper.jar
hs_err_pid*
replay_pid*

# Python (Tests / Helpers)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/

# IDE / Editor Files
.idea/
.vscode/
*.iml
*.ipr
*.iws
*.swp
*.swo
.project
.classpath
.settings/
.nb-confidence

# Logs
logs/
*.log

# Temp / Uploads
temp/
uploads/
.cache/
