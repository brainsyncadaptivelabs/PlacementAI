# ============================================================
# PlacementAI – Root Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ============================================================

# FRONTEND / BACKEND URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8080

# Web Push (VAPID)
VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:support@yourdomain.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=YOUR_NEXT_PUBLIC_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_NEXT_PUBLIC_SUPABASE_ANON_KEY

# Third-party auth providers
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
FACEBOOK_APP_ID=YOUR_FB_APP_ID
APPLE_CLIENT_ID=YOUR_APPLE_CLIENT_ID

# Database (PostgreSQL / Supabase)
DB_URL=jdbc:postgresql://localhost:5432/placementai
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_ROOT_PASSWORD=postgres
DB_NAME=placementai

# JWT
JWT_SECRET=YOUR_JWT_SECRET_KEY_MIN_256_BITS

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Ollama (Local LLM optional configuration)
OLLAMA_API_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=mistral
OLLAMA_TEMPERATURE=0.7
OLLAMA_TOP_P=0.9
OLLAMA_REPEAT_PENALTY=1.15
OLLAMA_NUM_CTX=8192
OLLAMA_NUM_PREDICT=4096

# Piston Code Execution
PISTON_API_URL=http://localhost:2000/api/v2
PISTON_API_WS_URL=ws://localhost:2000/api/v2/connect

# Mail configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=YOUR_MAIL_USERNAME
MAIL_PASSWORD=YOUR_MAIL_PASSWORD

# Supabase Storage
SUPABASE_STORAGE_BUCKET=placementai-files

# Admin Seeding
ADMIN_REGISTRATION_CODE=ADMIN123
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=YOUR_ADMIN_PASSWORD_BCRYPT_HASH

# NVIDIA Build API
NVIDIA_API_KEY=YOUR_NVIDIA_API_KEY
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_TEMPERATURE=0.2
NVIDIA_TOP_P=0.7
NVIDIA_MAX_TOKENS=1024
NVIDIA_TIMEOUT_SECONDS=120
NVIDIA_RETRY_ATTEMPTS=3
NVIDIA_RETRY_DELAY_MS=1000
